    "import sys\n",
    "from pathlib import Path\n",
    "import numpy as np\n",
    "\n",
    "if str(Path.cwd().parent) not in sys.path:\n",
    "    sys.path.append(str(Path.cwd().parent))\n",
    "\n",
    "from part1.ols_implementation import ols_fit, coef_inference\n",
    "\n",
    "# 1. Khởi tạo dữ liệu mẫu kiểm định (X_demo, y_demo)\n",
    "np.random.seed(42)\n",
    "X_demo = np.random.randn(100, 3)\n",
    "X_demo[:, 0] = 1.0  # Thêm cột Intercept\n",
    "\n",
    "# Thiết lập hệ số thực: Beta1 có ý nghĩa mạnh, Beta2 gần như bằng 0 (không ý nghĩa)\n",
    "beta_true = np.array([10.0, 5.0, 0.01])\n",
    "epsilon = np.random.normal(0, 0.5, 100)\n",
    "y_demo = X_demo @ beta_true + epsilon\n",
    "\n",
    "# 2. Chạy hồi quy OLS để lấy kết quả beta_hat và phương sai sai số sigma2\n",
    "beta_hat, sigma2 = ols_fit(X_demo, y_demo)\n",
    "\n",
    "# 3. Chạy hàm suy diễn thống kê cho các hệ số (Đã đồng bộ đúng 3 tham số đầu vào)\n",
    "inference_results = coef_inference(X_demo, beta_hat, sigma2)\n",
    "\n",
    "# 4. In kết quả trực quan ra màn hình Notebook\n",
    "print(\"--- KẾT QUẢ SUY DIỄN THỐNG KÊ (COEF INFERENCE) ---\")\n",
    "print(\"Standard Errors (SE):\\n\", inference_results[\"SE\"])\n",
    "print(\"t-statistics:\\n\", inference_results[\"t_stats\"])\n",
    "print(\"p-values:\\n\", inference_results[\"p_values\"])\n",
    "print(\"95% CI Lower Bound:\\n\", inference_results[\"CI_lower\"])\n",
    "print(\"95% CI Upper Bound:\\n\", inference_results[\"CI_upper\"])"
    "# Thêm đường dẫn gốc để Notebook nhận diện được thư mục part1\n",
    "if str(Path.cwd().parent) not in sys.path:\n",
    "    sys.path.append(str(Path.cwd().parent))\n",
    "\n",
    "from part1.ols_implementation import ols_fit, model_metrics\n",
    "\n",
    "# 1. Khởi tạo dữ liệu mẫu (X_demo, y_demo)\n",
    "np.random.seed(42)\n",
    "n_samples = 100\n",
    "X_demo = np.random.randn(n_samples, 3)\n",
    "X_demo[:, 0] = 1.0  # Thêm cột Intercept\n",
    "beta_true = np.array([2.5, 1.5, -0.8])\n",
    "y_demo = X_demo @ beta_true + np.random.normal(0, 0.1, n_samples)\n",
    "\n",
    "# 2. Chạy hồi quy OLS để lấy kết quả beta_hat\n",
    "beta_hat, sigma2 = ols_fit(X_demo, y_demo)\n",
    "\n",
    "# 3. Dự đoán y_hat và lấy số lượng biến độc lập p\n",
    "y_hat_demo = X_demo @ beta_hat\n",
    "p_features = X_demo.shape[1] - 1  # Bỏ cột intercept, p = 2 (Đảm bảo p > 0 như logic code)\n",
    "\n",
    "# 4. Chạy hàm đánh giá mô hình\n",
    "metrics_result = model_metrics(y_demo, y_hat_demo, p_features)\n",
    "\n",
    "# 5. In kết quả trực quan ra màn hình\n",
    "print(\"--- KẾT QUẢ ĐÁNH GIÁ MÔ HÌNH (MODEL METRICS) ---\")\n",
    "# Lọc ra các key chính để in, tránh in trùng lặp (ví dụ F_stat và F_statistic)\n",
    "keys_to_print = [\"RSS\", \"TSS\", \"R2\", \"Adjusted_R2\", \"F_statistic\", \"MAE\", \"RMSE\"]\n",
    "for key in keys_to_print:\n",
    "    value = metrics_result[key]\n",
    "    print(f\"{key}: {value:.4f}\")"
   ]
  }
